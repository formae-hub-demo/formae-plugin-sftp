/// SFTP plugin configuration.
/// Provides connection and behavior settings for the SFTP plugin.
extends "formae:/Config.pkl"

class PluginConfig extends BaseResourcePluginConfig {
    type = "sftp"

    /// Connection timeout in seconds for SFTP operations.
    /// Defaults to 30 seconds if not set.
    defaultTimeoutSeconds: Int = 30

    /// Maximum number of concurrent SFTP connections per target.
    /// Defaults to 5.
    maxConcurrentConnections: Int = 5
}
